datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Group {
  id        String  @id
  name      String
  subject   String?
  schedule  String?
  teacherId String?
  roomName  String?
  level     String?
  grade     String?

  students     Student[]
  regularSlots ScheduleSlot[] @relation("GroupRegularSlots")
  holidaySlots ScheduleSlot[] @relation("GroupHolidaySlots")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Student {
  id                   String    @id
  name                 String
  phone                String?
  sessionsSincePayment Int       @default(0)
  pricePerCycle        Float     @default(100.0)
  pricePerMonth        Float     @default(100.0)
  pricePerSession      Float     @default(30.0)
  monthlyExpiry        DateTime?
  groupId              String?
  email                String?
  originSchool         String?
  paymentMode          String    @default("cycle")

  group       Group?       @relation(fields: [groupId], references: [id])
  payments    Payment[]
  attendances Attendance[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Payment {
  id            String   @id
  date          DateTime
  amount        Float
  sessionsCount Int      @default(4)
  paymentType   String   @default("sessions")
  studentId     String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model ScheduleSlot {
  id          Int @id @default(autoincrement())
  dayOfWeek   Int
  startHour   Int
  startMinute Int
  endHour     Int
  endMinute   Int

  groupRegularId String?
  groupHolidayId String?

  groupRegular Group? @relation("GroupRegularSlots", fields: [groupRegularId], references: [id], onDelete: Cascade)
  groupHoliday Group? @relation("GroupHolidaySlots", fields: [groupHolidayId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        Int      @id @default(autoincrement())
  date      DateTime
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
